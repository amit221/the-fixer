# Required for Cursor CLI

CURSOR_API_KEY=



# GitHub: discovery and PR creation (scope: repo)

# https://github.com/settings/tokens

GITHUB_TOKEN=



# Discovery, filters, and agent model are fixed in src/orchestrator.py (top-level constants).

# Optional: append-only JSON Lines log for supervising agents (see README). Empty or 0 disables.
# IYNX_PROGRESS_JSONL=.iynx-run-progress.jsonl

# Docker: allocate a TTY for streamed runs so Cursor CLI stdout is line-buffered to the host (default 1). Set 0 if your environment rejects -t.
# IYNX_DOCKER_TTY=1

# Docker: timestamped [iynx-docker] lines inside container shells (clone, cursor, verify, PR). Default 1; set 0 for quieter runs.
# IYNX_DOCKER_TRACE=1

# Docker: bash set -x inside those shells (extremely verbose). Default 0.
# IYNX_DOCKER_XTRACE=0

# Cursor CLI (--print): stream-json + partial deltas for live [docker] logs (defaults). Use text for final answer only.
# IYNX_CURSOR_OUTPUT_FORMAT=stream-json
# IYNX_CURSOR_STREAM_PARTIAL=1

# Seconds per docker run (clone, each cursor-agent phase). Default 3600; increase if monorepo install + tests exceed an hour.
# IYNX_DOCKER_RUN_TIMEOUT=7200

# Headless: --yolo + --approve-mcps + --sandbox disabled (default 1). Set 0 to require explicit --force on later phases only.
# IYNX_CURSOR_PERMISSIVE=1

# Override default model (composer-2 in orchestrator.py).
# IYNX_CURSOR_MODEL=composer-2

# Extra cursor-agent CLI args (space-separated).
# IYNX_CURSOR_EXTRA_ARGS=
